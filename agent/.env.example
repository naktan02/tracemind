# TraceMind agent 로컬 개발 환경 설정 예시.
# TraceMind agent 로컬 개발 환경 설정 예시.
# 이 파일을 `agent/.env`로 복사한 뒤 로컬 값만 수정한다.

# agent API CORS 계층이 허용할 family extension dev server origin.
FAMILY_EXTENSION_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# 아이용 마음 도움 LLM provider.
# `local_guarded` 또는 `none`이면 deterministic guarded 응답만 사용한다.
# `ollama`이면 agent process가 로컬 Ollama server를 호출한다.
TRACEMIND_CHILD_SUPPORT_LLM_PROVIDER=ollama

# 모델은 실행할 때 shell 환경변수로 일시 override할 수 있다.
# TRACEMIND_CHILD_SUPPORT_OLLAMA_MODEL=qwen3:8b uv run uvicorn ...
TRACEMIND_CHILD_SUPPORT_OLLAMA_MODEL=exaone3.5:7.8b

# WSL에서 Windows Ollama에 붙을 때는 보통 vEthernet WSL gateway 주소를 쓴다.
TRACEMIND_CHILD_SUPPORT_OLLAMA_BASE_URL=http://192.168.192.1:11434

# captured text weak/strong view generation provider.
# 기본값은 none/identity fallback이다. 실제 NLLB 번역을 쓰려면 아래 provider를 켠다.
# 최초 실행은 모델 다운로드/로드 때문에 오래 걸릴 수 있다.
TRACEMIND_CAPTURED_TEXT_TRANSLATION_PROVIDER=none
TRACEMIND_CAPTURED_TEXT_STRONG_VIEW_PROVIDER=none

# NLLB를 켤 때의 기본 언어 설정.
# Korean -> English weak translation, English -> pivots -> English strong views.
TRACEMIND_CAPTURED_TEXT_TRANSLATION_SOURCE_LOCALE=ko
TRACEMIND_CAPTURED_TEXT_TRANSLATION_SOURCE_LANG=kor_Hang
TRACEMIND_CAPTURED_TEXT_TRANSLATION_TARGET_LANG=eng_Latn
TRACEMIND_CAPTURED_TEXT_STRONG_SOURCE_LANG=eng_Latn
TRACEMIND_CAPTURED_TEXT_STRONG_PIVOT_LANGS=fra_Latn,deu_Latn
TRACEMIND_CAPTURED_TEXT_NLLB_MODEL_ID=facebook/nllb-200-distilled-600M
TRACEMIND_CAPTURED_TEXT_NLLB_REVISION=main
TRACEMIND_CAPTURED_TEXT_NLLB_DEVICE=auto
TRACEMIND_CAPTURED_TEXT_NLLB_BATCH_SIZE=8
TRACEMIND_CAPTURED_TEXT_NLLB_MAX_NEW_TOKENS=256
TRACEMIND_CAPTURED_TEXT_NLLB_TORCH_DTYPE=auto
TRACEMIND_CAPTURED_TEXT_NLLB_LOCAL_FILES_ONLY=false
