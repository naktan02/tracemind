{
  "manifest_version": 3,
  "name": "TraceMind Family Extension",
  "version": "0.1.2",
  "description": "아이용 wellbeing signal과 부모용 보호 화면을 제공하는 TraceMind 확장 프로그램",
  "action": {
    "default_title": "TraceMind Family",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["assets/content.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ],
  "options_ui": {
    "page": "parent.html",
    "open_in_tab": true
  },
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "http://127.0.0.1:8001/*",
    "http://localhost:8001/*",
    "http://*/*",
    "https://*/*"
  ]
}
